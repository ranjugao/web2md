# API Keys (comma-separated, leave empty to auto-generate)
# API_KEYS=my-secret-key-1,my-secret-key-2

# Webhook: Push new scraped content to Telegram
# WEBHOOK_ENABLED=true
# WEBHOOK_URL=your-telegram-bot-token
# WEBHOOK_CHAT_ID=your-chat-id
# WEBHOOK_MIN_WORDS=50
# WEBHOOK_DOMAINS=news.ycombinator.com,bbc.com
